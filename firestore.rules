rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 채팅방 문서 자체: config/rooms에서 관리하므로 직접 접근 불필요 → 기본 deny
    match /rooms/{roomId} {
      allow read, write: if false;
    }

    // 채팅 메시지: rooms/{roomId}/messages — 로그인한 사용자만 읽기/쓰기 (익명 포함)
    match /rooms/{roomId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // 드라이버: drivers
    // - read: 로그인한 사용자 (로그인 검증·검색용)
    // - create: 로그인한 사용자 (회원가입용 — 익명 인증 포함 허용)
    // - update/delete: 관리자만 (role superAdmin 또는 company 관리자)
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자");
    }

    // 회원 프로필: users/{uid}
    // - 일반 사용자: 자신의 문서만 읽기/쓰기
    // - 관리자: 모든 사용자 문서 read/update 가능 (역할 관리용)
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자"
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자"
      );
    }

    // 앱 설정: config/{docId} — 소속 업체 목록(companies), 채팅방 목록(rooms) 등
    // write: isAdmin와 동일한 조건 (role superAdmin 또는 company 관리자)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자");
    }

    // GPS 운행 기록: tracks/{trackId}
    // - create/update: 로그인한 사용자 (기사가 GPS 위치 데이터 전송)
    // - read/delete: 관리자만 (role superAdmin 또는 company 관리자)
    match /tracks/{trackId} {
      allow create, update: if request.auth != null;
      allow read, delete: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자");

      // points 서브컬렉션 (crewtalk-admin 관제 시스템에서 조회 시 필요)
      match /points/{pointId} {
        allow read, delete: if request.auth != null &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "superAdmin" ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("company", "") == "관리자");
        allow create, update: if request.auth != null;
      }
    }
  }
}
